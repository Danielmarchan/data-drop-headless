{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:debug": "tsx watch --inspect src/server.ts",
    "build": "tsc --build && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.1",
    "@data-drop/api-schema": "workspace:*",
    "better-auth": "^1.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "drizzle-orm": "^0.41.0",
    "express": "^5.0.1",
    "express-actuator": "^1.8.4",
    "express-rate-limit": "^8.3.2",
    "express-winston": "^4.2.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "multer": "^2.1.1",
    "postgres": "^3.4.4",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-actuator": "^1.8.3",
    "@types/hpp": "^0.2.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.30.5",
    "openapi3-ts": "^4.5.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
